flowchart TD
    subgraph voice ["Per voice"]
        direction TB
        osc1[Osc 1]
        osc2[Osc 2]
        sub[Sub]
        noise[Noise]
        mix([Mixer])
        hpf[HPF]
        vcf["VCF<br/>LP / HP / BP / Notch"]
        vca[VCA]
        osc1 --> mix
        osc2 --> mix
        sub --> mix
        noise --> mix
        mix --> hpf --> vcf --> vca
    end
    subgraph inst ["Instrument bus (host sample rate)"]
        direction TB
        phaser[Phaser]
        chorus["BBD Chorus"]
        delay["Stereo Delay"]
        reverb["FDN Reverb"]
        master["Master<br/>(volume + optional limiter)"]
        phaser --> chorus --> delay --> reverb --> master
    end
    voice -- "voice mix" --> phaser
    master --> out([Stereo out])
